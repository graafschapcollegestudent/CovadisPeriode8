@page "/team"
@using System.Collections.Generic
@using Covadis.Frontend.DTOs
@using Covadis.Frontend.Models
@using Covadis.Frontend.Responses
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<h3>Mijn Team</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (team == null)
{
    <p>Laden...</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h4>@team.Name</h4>
        </div>
        <div class="card-body">
            <h5>Teamleden</h5>
            <ul>
                @foreach (var user in team.Users)
                {
                    <li>@user.FullName</li>
                }
            </ul>
        </div>
    </div>
    <h5>Taken</h5>
    <input @bind="searchTitle" placeholder="Zoek op titel..." class="form-control mb-2" />
    <input @bind="minDuration" type="number" placeholder="Min. uren" class="form-control mb-2" />
    <input @bind="maxDuration" type="number" placeholder="Max. uren" class="form-control mb-2" />
    <select @bind="sortBy" class="form-select mb-2">
        <option value="">-- Sorteren op --</option>
        <option value="title">Titel</option>
        <option value="duration">Tijdsduur</option>
        <option value="date">Datum</option>
    </select>

    <select @bind="sortOrder" class="form-select mb-2">
        <option value="asc">Oplopend</option>
        <option value="desc">Aflopend</option>
    </select>
    @if (team.Tasks.Count == 0)
    {
        <p>Geen taken gevonden.</p>
    }
    else
    {
        <ul>
            @foreach (var task in FilteredTasks)
            {
                <li>
                    <strong>@task.Title</strong> — @task.Description
                    <br />
                   <small>Status: @((Status)task.Status) | Deadline: @task.DueDate.ToShortDateString()</small>
                </li>
            }
        </ul>
        <div class="d-flex justify-content-between align-items-center mt-2">
            <button class="btn btn-secondary" disabled="@(currentPage <= 1)" @onclick="() => currentPage--">Vorige</button>
            <span>Pagina @currentPage van @totalPages</span>
            <button class="btn btn-secondary" disabled="@(currentPage >= totalPages)" @onclick="() => currentPage++">Volgende</button>
        </div>
        <select @bind="pageSize" class="form-select mb-2" style="width: 150px;">
            <option value="5">5 per pagina</option>
            <option value="10">10 per pagina</option>
            <option value="25">25 per pagina</option>
        </select>
    }
}

@code {
    private TeamReadDto? team;
    private string? errorMessage;
    private string searchTitle = "";
    private int? minDuration;
    private int? maxDuration;
    private string sortBy = "";
    private string sortOrder = "asc";
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((double)FilteredTasksAll.Count() / pageSize);

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
        if (string.IsNullOrEmpty(token))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        var payload = token.Split('.')[1];
        var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(PadBase64(payload)));
        var claims = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(json);
        string teamId = string.Empty;
        if (claims != null && claims.TryGetValue("teamId", out var teamIdObj))
        {
            teamId = teamIdObj?.ToString() ?? string.Empty;
        }
        if (string.IsNullOrEmpty(teamId))
        {
            errorMessage = "Je bent niet gekoppeld aan een team.";
            return;
        }
        var result = await Http.GetFromJsonAsync<ApiResponse<TeamReadDto>>($"api/team/{teamId}");
        team = result?.Data;
    }

    private string PadBase64(string base64)
    {
        return base64.PadRight(base64.Length + (4 - base64.Length % 4) % 4, '=');
    }

    private IEnumerable<TaskReadDto> FilteredTasksAll
    {
        get
        {
            var tasks = (team?.Tasks ?? Enumerable.Empty<TaskReadDto>())
                .Where(t =>
                    (string.IsNullOrWhiteSpace(searchTitle) || t.Title.Contains(searchTitle, StringComparison.OrdinalIgnoreCase))
                    && (minDuration == null || t.EstimatedDuration >= minDuration)
                    && (maxDuration == null || t.EstimatedDuration <= maxDuration)
                );

            tasks = sortBy switch
            {
                "title" => sortOrder == "asc" ? tasks.OrderBy(t => t.Title) : tasks.OrderByDescending(t => t.Title),
                "duration" => sortOrder == "asc" ? tasks.OrderBy(t => t.EstimatedDuration) : tasks.OrderByDescending(t => t.EstimatedDuration),
                "date" => sortOrder == "asc" ? tasks.OrderBy(t => t.DueDate) : tasks.OrderByDescending(t => t.DueDate),
                _ => tasks
            };

            return tasks;
        }
    }

    private IEnumerable<TaskReadDto> FilteredTasks => FilteredTasksAll
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);
}