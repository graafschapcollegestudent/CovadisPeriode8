@page "/manager/team/{teamId}"
@using Covadis.Frontend.DTOs
@using Covadis.Frontend.Models
@using Covadis.Frontend.Responses
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<h3>Taken van team</h3>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (team == null)
{
    <p>Laden...</p>
}
else
{
    <div class="card mb-3">
        <div class="card-header">
            <h4>@team.Name</h4>
        </div>
        <div class="card-body">
            @if (team.Tasks.Count == 0)
            {
                <p>Geen taken gevonden.</p>
            }
            else
            {
                <ul>
                    @foreach (var task in team.Tasks)
                    {
                        <li>
                            <strong>@task.Title</strong> — @task.Description
                            <br />
                            <small>Status: @((Status)task.Status) | Sprint: @task.SprintNumber | Deadline: @task.DueDate.ToShortDateString() | Duur: @task.EstimatedDuration uur</small>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
    <a href="/manager/teams" class="btn btn-secondary">Terug naar teams</a>
}

@code {
    [Parameter]
    public string teamId { get; set; } = string.Empty;

    private TeamReadDto? team;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "token");
            if (string.IsNullOrEmpty(token))
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            var payload = token.Split('.')[1];
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(PadBase64(payload)));
            var claims = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(json);
            string role = string.Empty;
            if (claims != null && claims.TryGetValue("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", out var roleObj))
            {
                role = roleObj?.ToString() ?? string.Empty;
            }

            if (role != "Manager")
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            var result = await Http.GetFromJsonAsync<ApiResponse<TeamReadDto>>($"api/team/{teamId}");
            team = result?.Data;
            StateHasChanged();
        }
    }

    private string PadBase64(string base64)
    {
        return base64.PadRight(base64.Length + (4 - base64.Length % 4) % 4, '=');
    }
}